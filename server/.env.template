# ─────────────────────────────────────────────────
# Rock Merch & Roll — Template de Variables de Entorno
# ─────────────────────────────────────────────────
# Copiá las variables que necesites a server/.env.
# El servidor carga .env automáticamente al arrancar.
# ─────────────────────────────────────────────────

# ── Servidor ──────────────────────────────────────
PORT=4000

# Clave secreta para firmar JWTs (cambiar en producción)
JWT_SECRET=rmr-dev-secret

# Email y contraseña del admin que se crea al seedear la DB
ADMIN_EMAIL=admin@rock.com
ADMIN_PASSWORD=admin123

# ── SMTP (Email) ──────────────────────────────────
# Si no se setean HOST/PORT/USER/PASS,
# los emails se loguean a consola en modo mock.
#
# Opción A — Mailtrap (pruebas):
#   https://mailtrap.io → Email Testing → SMTP Settings
#   SMTP_HOST=sandbox.smtp.mailtrap.io
#   SMTP_PORT=2525
#   SMTP_USER=tu-usuario-mock
#   SMTP_PASS=tu-pass-mock
#
# Opción B — Gmail (requiere contraseña de aplicación):
#   https://support.google.com/accounts/answer/185833
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=tuemail@gmail.com
#   SMTP_PASS=xxxx xxxx xxxx xxxx
#
# Opción C — SMTP propio:
#   SMTP_HOST=mail.tudominio.com
#   SMTP_PORT=587
#   SMTP_USER=no-reply@tudominio.com
#   SMTP_PASS=tu-contraseña-real
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=

# Dirección "from" de todos los emails salientes
SMTP_FROM=Rock Merch & Roll <tuemail@gmail.com>

# ── Frontend URL (para links absolutos en emails) ──
RMR_APP_URL=http://localhost:3000

# ── PostgreSQL (producción) ────────────────────────
# Opción A — DATABASE_URL (recomendado, compatible con Render / Neon)
#   DATABASE_URL=postgresql://user:password@host:5432/rockmerch?sslmode=require
#
# Opción B — Variables individuales
#   PGHOST=localhost
#   PGPORT=5432
#   PGDATABASE=rockmerch
#   PGUSER=postgres
#   PGPASSWORD=postgres
